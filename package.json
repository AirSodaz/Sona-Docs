{
  "name": "sona-docs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "audit": "pnpm audit --audit-level moderate",
    "ci:pr": "pnpm lint && pnpm test && pnpm build && pnpm audit --audit-level moderate",
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.38.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "0.0.1",
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
