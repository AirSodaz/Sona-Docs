# Preferred public origin for metadata, sitemap, robots, and social tags.
SITE_URL="https://sona.example.com"

# Optional backwards-compatible fallback.
# NEXT_PUBLIC_SITE_URL="https://sona.example.com"

# Optional but recommended to avoid GitHub API rate limits on /api/github-release.
# Use a read-only token with access to public repositories.
# GITHUB_TOKEN="your_github_token_here"

# Optional Gemini API key for the user-guide AI Q&A card.
# When omitted, the guide still renders but AI questions stay disabled.
# GEMINI_API_KEY="your_gemini_api_key_here"

# Required for the protected guide AI route in production.
# Use a long random secret for signing anonymous anti-abuse cookies.
# API_ABUSE_SECRET="replace_with_a_long_random_secret"

# Required for protected guide AI in production.
# Comma-separated hostnames that are allowed to use the AI route.
# ALLOWED_PUBLIC_HOSTS="sona.example.com"

# Required for the Turnstile challenge shown after anonymous usage thresholds.
# TURNSTILE_SITE_KEY="your_turnstile_site_key"
# TURNSTILE_SECRET_KEY="your_turnstile_secret_key"

# Optional model override for guide-only Q&A.
# Defaults to gemini-2.5-flash.
# GEMINI_GUIDE_MODEL="gemini-2.5-flash"
